// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model userData {
  userId        String          @id
  userFullName  String
  userEmail     String          @unique
  userPassword  String
  resumeData    resumeData[]
  comments      comments[]
  codeInterview codeInterview[]
  mockInterview mockInterview[]

  @@index([userEmail])
}

model resumeData {
  resumeId       String   @id
  userId         String
  user           userData @relation(fields: [userId], references: [userId])
  resumeCloudUrl String
  skills         String[] @default([])
  experience     Int
  Timestamp      DateTime @default(now())
}

model codeInterview {
  codeIntId String   @id
  userId    String
  user      userData @relation(fields: [userId], references: [userId])
  language  String
  level     String
  time      BigInt
  question  String
  code      String
  output    String
  feedBack  String
  Timestamp DateTime @default(now())
}

model mockInterview {
  mockIntId     String   @id
  userId        String
  user          userData @relation(fields: [userId], references: [userId])
  interviewType String
  level         String
  feedback      Json[]   @default([])
  Timestamp     DateTime @default(now())
}

model practiceQuestions {
  questionId String     @id
  question   String
  type       String
  skill      String
  level      String
  comments   comments[]
}

model comments {
  commentId         String            @id
  questionId        String
  practiceQuestions practiceQuestions @relation(fields: [questionId], references: [questionId])
  userId            String
  user              userData          @relation(fields: [userId], references: [userId])
  userFullName      String
  Timestamp         DateTime          @default(now())
}
